{
  "name": "drusniel-voxels-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone Three.js/TypeScript voxel terrain viewer.",
  "scripts": {
    "spike": "tsx src/spike.ts",
    "build-pages": "tsx src/build.ts",
    "qa": "tsx src/qa.ts",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
